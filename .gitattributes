# =======================================================
# 换行符策略：所有文本文件统一 LF（详见 CLAUDE.md 协作规范）
# =======================================================

# 默认：git 自动识别文本文件，并在 checkout 时统一为 LF
* text=auto eol=lf

# 明确指定常见文本类型使用 LF
*.md     text eol=lf
*.markdown  text eol=lf
*.sh     text eol=lf
*.bash   text eol=lf
*.conf   text eol=lf
*.ini    text eol=lf
*.json   text eol=lf
*.txt    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.csv    text eol=lf
*.tsv    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.py     text eol=lf
*.sql    text eol=lf
*.env    text eol=lf
*.md5    text eol=lf
*.svg    text eol=lf

# Windows 专属脚本保留 CRLF（避免在 Windows 上无法执行）
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# 二进制文件不做换行符转换
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.ico    binary
*.pdf    binary
*.doc    binary
*.docx   binary
*.xls    binary
*.xlsx   binary
*.ppt    binary
*.pptx   binary
*.zip    binary
*.gz     binary
*.tar    binary
*.tgz    binary
*.7z     binary
*.rar    binary
*.dat    binary
*.class  binary
*.jar    binary
